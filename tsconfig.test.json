{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-build",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/lib/dota/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".next", ".test-build"]
}
